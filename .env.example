# База данных PostgreSQL
DATABASE_URL=postgresql://tooluser:toolpassword@localhost:5432/toolmanagement
DB_HOST=postgres
DB_PORT=5432
DB_NAME=toolmanagement
DB_USER=tooluser
DB_PASSWORD=toolpassword

# JWT
JWT_SECRET=super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d

# Backend
PORT=5000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Файлы (загрузка фото)
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880
